  if (feedFilter === 'flag2' && risk.level !== 2) return;
  if (chatSearchTerm && text.toLowerCase().indexOf(chatSearchTerm) === -1 && username.toLowerCase().indexOf(chatSearchTerm) === -1) return;
  _origRenderTwitchMsg(username, text, channel);
};

